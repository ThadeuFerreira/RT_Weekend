{
    "version": "0.2.0",
    "configurations": [
        // Debug builds have tracing enabled (Render → Start/Stop Benchmark; trace JSON saved under build/ via TRACE_OUTPUT_FILE).
        {
            "name": "Debug (Windows)",
            "type": "cppvsdbg",
            "request": "launch",
            "preLaunchTask": "build-windows",
            "program": "${workspaceFolder}/build/debug.exe",
            "args": ["-w", "400", "-h", "225", "-s", "10", "-c", "4"],
            "cwd": "${workspaceFolder}",
            "environment": [
                { "name": "TRACE_OUTPUT_FILE", "value": "build" }
            ]
        },
        {
            "name": "Debug (Linux)",
            "type": "cppdbg",
            "request": "launch",
            "preLaunchTask": "build-linux",
            "program": "${workspaceFolder}/build/debug",
            "args": ["-w", "400", "-h", "225", "-s", "10", "-c", "4"],
            "cwd": "${workspaceFolder}",
            "environment": [
                { "name": "TRACE_OUTPUT_FILE", "value": "build" }
            ],
            "miDebuggerPath": "/usr/bin/gdb"
        },
        {
            "name": "Debug (Linux) Large",
            "type": "cppdbg",
            "request": "launch",
            "preLaunchTask": "build-linux",
            "program": "${workspaceFolder}/build/debug",
            "args": ["-w", "1600", "-h", "900", "-s", "100", "-c", "8"],
            "cwd": "${workspaceFolder}",
            "environment": [
                { "name": "TRACE_OUTPUT_FILE", "value": "build" }
            ],
            "miDebuggerPath": "/usr/bin/gdb"
        },
        {
            "name": "Debug (Linux, small)",
            "type": "cppdbg",
            "request": "launch",
            "preLaunchTask": "build-linux",
            "program": "${workspaceFolder}/build/debug",
            "args": ["-w", "160", "-h", "90", "-s", "2", "-n", "2", "-c", "2"],
            "cwd": "${workspaceFolder}",
            "environment": [
                { "name": "TRACE_OUTPUT_FILE", "value": "build" }
            ],
            "miDebuggerPath": "/usr/bin/gdb"
        },
        {
            "name": "Debug (Linux) GPU",
            "type": "cppdbg",
            "request": "launch",
            "preLaunchTask": "build-linux",
            "program": "${workspaceFolder}/build/debug",
            "args": ["-w", "400", "-h", "225", "-s", "10", "-c", "4", "-gpu"],
            "cwd": "${workspaceFolder}",
            "environment": [
                { "name": "TRACE_OUTPUT_FILE", "value": "build" }
            ],
            "miDebuggerPath": "/usr/bin/gdb"
        },
        {
            "name": "Debug (Linux) Large GPU",
            "type": "cppdbg",
            "request": "launch",
            "preLaunchTask": "build-linux",
            "program": "${workspaceFolder}/build/debug",
            "args": ["-w", "1600", "-h", "900", "-s", "100", "-c", "8", "-gpu", "--scene", "resources/scenes/scene_4.json"],
            "cwd": "${workspaceFolder}",
            "environment": [
                { "name": "TRACE_OUTPUT_FILE", "value": "build" }
            ],
            "miDebuggerPath": "/usr/bin/gdb"
        },
        {
            "name": "Debug (Linux) Earth",
            "type": "cppdbg",
            "request": "launch",
            "preLaunchTask": "build-linux",
            "program": "${workspaceFolder}/build/debug",
            "args": ["-w", "1600", "-h", "900", "-s", "100", "-c", "8", "-gpu", "-scene", "earth"],
            "cwd": "${workspaceFolder}",
            "environment": [
                { "name": "TRACE_OUTPUT_FILE", "value": "build" }
            ],
            "miDebuggerPath": "/usr/bin/gdb"
        },
        {
            "name": "Debug (Linux, small) GPU",
            "type": "cppdbg",
            "request": "launch",
            "preLaunchTask": "build-linux",
            "program": "${workspaceFolder}/build/debug",
            "args": ["-w", "160", "-h", "90", "-s", "2", "-n", "2", "-c", "2", "-gpu"],
            "cwd": "${workspaceFolder}",
            "environment": [
                { "name": "TRACE_OUTPUT_FILE", "value": "build" }
            ],
            "miDebuggerPath": "/usr/bin/gdb"
        },
        {
            "name": "Release (Linux)",
            "type": "cppdbg",
            "request": "launch",
            "preLaunchTask": "build-linux-release",
            "program": "${workspaceFolder}/build/release",
            "args": ["-w", "400", "-h", "225", "-s", "10", "-c", "4"],
            "cwd": "${workspaceFolder}",
            "miDebuggerPath": "/usr/bin/gdb"
        },
        {
            "name": "Release (Linux) GPU",
            "type": "cppdbg",
            "request": "launch",
            "preLaunchTask": "build-linux-release",
            "program": "${workspaceFolder}/build/release",
            "args": ["-w", "400", "-h", "225", "-s", "10", "-c", "4", "-gpu"],
            "cwd": "${workspaceFolder}",
            "miDebuggerPath": "/usr/bin/gdb"
        },
        {
            "name": "Release (Windows)",
            "type": "cppvsdbg",
            "request": "launch",
            "preLaunchTask": "build-windows-release",
            "program": "${workspaceFolder}/build/release.exe",
            "args": ["-w", "400", "-h", "225", "-s", "10", "-c", "4"],
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Release (Windows) GPU",
            "type": "cppvsdbg",
            "request": "launch",
            "preLaunchTask": "build-windows-release",
            "program": "${workspaceFolder}/build/release.exe",
            "args": ["-w", "400", "-h", "225", "-s", "10", "-c", "4", "-gpu"],
            "cwd": "${workspaceFolder}"
        }
    ]
}
