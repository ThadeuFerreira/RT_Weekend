#version 450

layout(local_size_x = 8, local_size_y = 8) in;

const int MAT_LAMBERTIAN    = 0;
const int MAT_METALLIC      = 1;
const int MAT_DIELECTRIC    = 2;
const int MAT_DIFFUSE_LIGHT = 3;
const int MAT_ISOTROPIC     = 4;

const int TEX_CONSTANT = 0;
const int TEX_CHECKER  = 1;
const int TEX_IMAGE    = 2;
const int TEX_NOISE    = 3;
const int TEX_MARBLE   = 4;

const int LEAF_SPHERE = -1;
const int LEAF_QUAD   = -2;
const int LEAF_VOLUME = -3;

layout(set = 0, binding = 0, std140) uniform CameraBlock {
    vec4 camera_center;
    vec4 pixel00_loc;
    vec4 pixel_delta_u;
    vec4 pixel_delta_v;
    vec4 defocus_disk_u;
    vec4 defocus_disk_v;
    int  width;
    int  height;
    int  max_depth;
    int  total_samples;
    int  current_sample;
    int  _pad0, _pad1, _pad2;
    vec4 background;
};

struct Ray { vec3 origin; float _pad0; vec3 dir; float time; };
struct Sphere {
    Ray   center;
    float radius;
    float _pad_r[3];
    vec3  albedo;
    int   mat_type;
    float fuzz_or_ior;
    float _pad[3];
    int   tex_type;
    float tex_scale;
    float _pad_tex[2];
    vec3  tex_even;
    float _pad_even;
    vec3  tex_odd;
    float _pad_odd;
    int   tex_index;
    float _pad_stride[3];
};
struct BVHNode { vec3 aabb_min; int right_or_obj_idx; vec3 aabb_max; int left_idx; };
struct Quad {
    vec3  Q; float _pad0;
    vec3  u; float _pad1;
    vec3  v; float _pad2;
    vec3  w; float _pad3;
    vec3  normal; float _pad4;
    float D; int mat_type; float _pad5[2];
    vec3  albedo; float _pad6;
    float fuzz_or_ior; int tex_type; float tex_scale; float _pad7[2];
    float _pad_align_tex[3];
    vec3  tex_even; float _pad8;
    vec3  tex_odd;  float _pad9;
};
struct Volume {
    float density; float _pad_d[3];
    vec3  albedo;  float _pad_a;
    int   quad_start;
    int   _pad_stride[3];
};
struct HitRecord {
    vec3 p, normal;
    float t;
    bool front_face;
    float u, v;
    int mat_type;
    vec3 albedo;
    float fuzz_or_ior;
    float ray_time;
    int tex_type;
    float tex_scale;
    vec3 tex_even;
    vec3 tex_odd;
    int tex_index;
};

layout(set = 0, binding = 1, std430) readonly buffer SpheresBlock {
    int sphere_count;
    int _sphere_pad[3];
    Sphere spheres[];
};
layout(set = 0, binding = 2, std430) readonly buffer BVHBlock {
    int bvh_count;
    int _bvh_pad[3];
    BVHNode bvh_nodes[];
};
layout(set = 0, binding = 3, std430) buffer OutputBlock {
    vec4 pixels[];
};
layout(set = 0, binding = 4, std430) readonly buffer QuadsBlock {
    int quad_count;
    int _quad_pad[3];
    Quad quads[];
};
layout(set = 0, binding = 5, std430) readonly buffer VolumesBlock {
    int volume_count;
    int _vol_pad[3];
    Volume volumes[];
};
layout(set = 0, binding = 6, std430) readonly buffer VolumeQuadsBlock {
    int volume_quad_count;
    int _vq_pad[3];
    Quad volume_quads[];
};
layout(set = 0, binding = 7, std430) readonly buffer ImageTextureBlock {
    int image_tex_count;
    int _img_pad[3];
    int image_tex_data[];  // metadata (width, height, pixel_offset, pad) per image, then packed RGB pixels
};

